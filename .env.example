# --- WorkOS AuthKit ---
# Get these from the WorkOS dashboard (https://dashboard.workos.com).
# This file is committed — keep it as placeholders. Real values go in .env.local.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# 32+ character random string used to encrypt session cookies.
# Generate one with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=

# Redirect URI registered for this environment in the WorkOS dashboard.
# Local dev:    http://localhost:3000/callback
# Production:   https://yourdomain.com/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Site ---
# Canonical site URL, used for metadataBase, OpenGraph absolute URLs,
# sitemap, and robots.txt. Must NOT end with a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (Neon Postgres via Vercel) ---
# Both values are auto-populated by Vercel when you connect the Neon
# integration. Copy them into .env.local for local development.
#
# DATABASE_URL          → pooled connection (used by the app at runtime)
# DATABASE_URL_UNPOOLED → direct connection (used by drizzle-kit for DDL)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Stripe ---
# Secret key from https://dashboard.stripe.com → Developers → API keys.
# Use the test key (sk_test_…) for development and the live key in prod.
STRIPE_SECRET_KEY=

# Signing secret for the webhook endpoint:
#   - Local dev:  run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#                 and copy the whsec_… value it prints
#   - Production: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Lookup key OR raw price id for the monthly subscription product.
# This MUST be a recurring (subscription) Price in Stripe — e.g. $500/month.
# Recommended: set "subscription_monthly_v1" as the Lookup key on your Price,
# then put that string here so you can change the underlying price later
# without a code deploy.
STRIPE_PRICE_MONTHLY=subscription_monthly_v1

# Lookup key OR raw price id for the YEARLY subscription product (optional).
# Must be a recurring Price with interval=year — e.g. $5,400/year (10% off
# the $6,000 annual-equivalent of the monthly plan). If unset, the pricing
# page shows the monthly plan only. The "save X%" badge is computed at
# runtime from the two prices, so set the Stripe amount to whatever discount
# you actually want.
STRIPE_PRICE_YEARLY=subscription_yearly_v1

# OAuth client id for Stripe Connect (ca_…), from Stripe → Connect → Settings →
# "OAuth settings". This lets orgs connect THEIR Stripe account (read-only) so
# we can read their data for reports — distinct from STRIPE_SECRET_KEY, which is
# our own billing account. You must also register the redirect URI there:
#   Local dev:   http://localhost:3000/api/integrations/stripe/callback
#   Production:  https://yourdomain.com/api/integrations/stripe/callback
STRIPE_CONNECT_CLIENT_ID=

# --- HubSpot integration ---
# OAuth app credentials from a HubSpot developer account (https://app.hubspot.com/
# → Developer account → Apps → your app → Auth). Lets orgs connect their HubSpot
# portal so we can read CRM/pipeline data for reports. Register the redirect URL
# on the app's Auth tab:
#   Local dev:   http://localhost:3000/api/integrations/hubspot/callback
#   Production:  https://yourdomain.com/api/integrations/hubspot/callback
# Scopes: crm.objects.deals.read, crm.objects.companies.read,
#         crm.objects.contacts.read, crm.schemas.deals.read, oauth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# --- Integration token encryption ---
# 32-byte key used to encrypt stored OAuth tokens (e.g. HubSpot refresh tokens)
# at rest with AES-256-GCM. Generate with: openssl rand -hex 32
INTEGRATION_TOKEN_KEY=

# --- Resend (transactional email) ---
# API key from https://resend.com/api-keys (re_…).
RESEND_API_KEY=

# Verified sender. The domain in the email address must be verified at
# https://resend.com/domains first. Format: "Name <address@domain>".
# e.g. "DeckForge <hello@mail.luistchitue.com>"
RESEND_FROM_EMAIL=

# --- Per-template launch URLs ---
# One URL per template, ordered to match the gallery (newest-first by
# publishedAt). Used by the "Open template" link on /templates/[slug];
# any unset slot renders "Coming soon" instead.
#   1. series-a-data-room
#   2. north-star-pitch
#   3. quarterly-business-review
#   4. people-all-hands
#   5. revenue-playbook
#   6. growth-experiment-report
#   7. fp-and-a-monthly-close
#   8. ops-incident-review
NEXT_PUBLIC_TEMPLATE_ONE_URL=
NEXT_PUBLIC_TEMPLATE_TWO_URL=
NEXT_PUBLIC_TEMPLATE_THREE_URL=
NEXT_PUBLIC_TEMPLATE_FOUR_URL=
NEXT_PUBLIC_TEMPLATE_FIVE_URL=
NEXT_PUBLIC_TEMPLATE_SIX_URL=
NEXT_PUBLIC_TEMPLATE_SEVEN_URL=
NEXT_PUBLIC_TEMPLATE_EIGHT_URL=
